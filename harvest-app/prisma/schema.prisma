generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  REP
  UPLINE
  ADMIN
  DUAL
  RVP
  EXTERNAL
}

enum OrgType {
  PRIMERICA
  EXTERNAL
}

enum AccessTier {
  FREE
  ESSENTIAL
  PRO
  ELITE
}

enum OnboardingStep {
  REGISTER
  ACCOUNT_TYPE
  SEVEN_WHYS
  GOAL_CARD
  INTENSITY
  COMPLETE
}

enum CFEOutcome {
  PASS
  FLAG
  BLOCK
}

enum PipelineStage {
  NEW
  ENGAGED
  PIPELINE
  ACTIVATED
  ARCHIVED
}

enum ContactDataClassification {
  PUBLIC
  INTERNAL
  CONFIDENTIAL
  RESTRICTED
}

enum ImportJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  PARTIAL
}

enum ImportSource {
  IOS_CONTACTS
  ANDROID_CONTACTS
  CSV_UPLOAD
  MANUAL_ENTRY
}

model AuditEntry {
  id              String     @id @default(uuid())
  user_id         String
  content_text    String
  content_hash    String
  risk_score      Int
  outcome         CFEOutcome
  classifier_data Json
  rule_version    String
  regulation      String
  reviewer_id     String?
  reviewer_action String?
  role            Role       @default(REP)
  created_at      DateTime   @default(now())

  @@index([created_at])
  @@index([user_id, created_at])
}

model ComplianceConsent {
  id              String   @id @default(uuid())
  user_id         String
  consent_type    String
  given           Boolean
  timestamp       DateTime @default(now())

  @@index([timestamp])
  @@index([user_id, timestamp])
}

model ComplianceRule {
  id              String   @id @default(uuid())
  name            String
  regulation      String
  version         String
  parameters      Json
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now())
}

model ComplianceReviewQueue {
  id              String   @id @default(uuid())
  audit_entry_id  String   @unique
  status          String
  upline_id       String
  created_at      DateTime @default(now())
}

model ComplianceUplineReview {
  id              String   @id @default(uuid())
  audit_entry_id  String
  reviewer_id     String
  action          String
  feedback        String?
  timestamp       DateTime @default(now())
}

model ComplianceException {
  id              String   @id @default(uuid())
  audit_entry_id  String
  reason          String
  created_at      DateTime @default(now())
}

model UserDataExport {
  id              String   @id @default(uuid())
  user_id         String
  status          String
  expires_at      DateTime
  created_at      DateTime @default(now())
}

model UserDataDeletion {
  id              String   @id @default(uuid())
  user_id         String
  status          String
  anonymized_fields String[]
  requested_at    DateTime @default(now())
  completed_at    DateTime?
}

model Organization {
  id         String   @id @default(uuid())
  name       String
  type       OrgType
  created_at DateTime @default(now())
  users      User[]
}

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  password_hash   String
  name            String
  phone           String?
  role            Role      @default(REP)
  org_type        OrgType   @default(EXTERNAL)
  solution_number String?
  upline_id       String?
  upline          User?     @relation("UserUpline", fields: [upline_id], references: [id])
  downlines       User[]    @relation("UserUpline")
  access_tier     AccessTier @default(FREE)
  commitment_score Int      @default(0)
  organization_id String?
  organization    Organization? @relation(fields: [organization_id], references: [id])
  contacts        Contact[] @relation("UserContacts")
  importJobs      ContactImportJob[] @relation("UserImportJobs")
  earningsSnapshots HiddenEarningsSnapshot[] @relation("UserEarningsSnapshots")
  onboarding_sessions OnboardingSession[]
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
}

model OnboardingSession {
  id            String   @id @default(uuid())
  user_id       String
  user          User     @relation(fields: [user_id], references: [id])
  current_step  OnboardingStep @default(REGISTER)
  seven_whys    Json?
  goal_card     Json?
  intensity_data Json?
  completed     Boolean  @default(false)
  created_at    DateTime @default(now())
}

model Contact {
  id                     String                @id @default(uuid())
  user_id                String                @map("user_id")
  user                   User                  @relation("UserContacts", fields: [user_id], references: [id])
  first_name             String                @map("first_name")
  last_name              String                @map("last_name")
  phone                  String?
  email                  String?
  relationship_type      String                @map("relationship_type")
  pipeline_stage         PipelineStage         @default(NEW) @map("pipeline_stage")
  segment_score          Int                   @default(0) @map("segment_score")
  segment_score_factors  Json?                 @map("segment_score_factors")
  is_recruit_target      Boolean               @default(false) @map("is_recruit_target")
  is_client              Boolean               @default(false) @map("is_client")
  is_a_list              Boolean               @default(false) @map("is_a_list")
  last_contact_date      DateTime?             @map("last_contact_date")
  notes                  String?
  source                 String
  import_batch_id        String?               @map("import_batch_id")
  data_classification    ContactDataClassification @default(RESTRICTED) @map("data_classification")
  consent_given_at       DateTime?             @map("consent_given_at")
  encrypted_pii_payload  String?               @map("encrypted_pii_payload")
  encrypted_pii_iv       String?               @map("encrypted_pii_iv")
  encrypted_pii_auth_tag String?               @map("encrypted_pii_auth_tag")
  life_events            Json?                 @map("life_events")
  trust_score            Int?                  @map("trust_score")
  created_at             DateTime              @default(now()) @map("created_at")
  updated_at             DateTime              @updatedAt @map("updated_at")

  interactions           ContactInteraction[]

  @@index([user_id, phone])
  @@index([user_id, email])
  @@index([user_id, pipeline_stage])
  @@map("contacts")
}

model ContactInteraction {
  id          String   @id @default(uuid())
  contact_id  String   @map("contact_id")
  contact     Contact  @relation(fields: [contact_id], references: [id])
  type        String
  timestamp   DateTime @default(now())
  details     String?

  @@index([contact_id, timestamp])
  @@map("contact_interactions")
}

model HiddenEarningsSnapshot {
  id                        String   @id @default(uuid())
  user_id                   String   @map("user_id")
  user                      User     @relation("UserEarningsSnapshots", fields: [user_id], references: [id])
  total_contacts            Int      @map("total_contacts")
  segment_breakdown         Json     @map("segment_breakdown")
  estimated_appointments    Int      @map("estimated_appointments")
  estimated_clients         Int      @map("estimated_clients")
  avg_monthly_value         Int      @map("avg_monthly_value")
  estimated_monthly_value   Int      @map("estimated_monthly_value")
  disclaimer_text           String   @map("disclaimer_text")
  calculated_at             DateTime @default(now()) @map("calculated_at")

  @@unique([user_id])
  @@index([user_id, calculated_at])
  @@map("hidden_earnings_snapshots")
}

model ContactImportJob {
  id                  String         @id @default(uuid())
  user_id             String         @map("user_id")
  user                User           @relation("UserImportJobs", fields: [user_id], references: [id])
  source              ImportSource   @map("source")
  status              ImportJobStatus @default(PENDING) @map("status")
  total_records       Int            @default(0) @map("total_records")
  imported_count      Int            @default(0) @map("imported_count")
  skipped_count       Int            @default(0) @map("skipped_count")
  error_count         Int            @default(0) @map("error_count")
  field_mapping       Json?          @map("field_mapping")
  conflict_resolution String?        @map("conflict_resolution")
  error_details       Json?          @map("error_details")
  started_at          DateTime?      @map("started_at")
  completed_at        DateTime?      @map("completed_at")
  created_at          DateTime       @default(now()) @map("created_at")

  @@index([user_id, status])
  @@map("contact_import_jobs")
}

// ─── WP04 Agent Layer Models ───────────────────────────────────────────

enum AgentType {
  PROSPECTING
  PRE_SALE_NURTURE
  POST_SALE_NURTURE
  APPOINTMENT
  REPORTING
  QUOTA
  IPA_VALUE
  INACTIVITY_REENGAGEMENT
}

enum AgentActionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  BLOCKED_BY_COMPLIANCE
  HELD_FOR_REVIEW
}

enum InactivityLevel {
  NONE
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ThreeLaw {
  GROW_DOWNLINE
  ENGAGE_BASE
  INCREASE_WEALTH
}

model AgentActionRecord {
  id              String            @id @default(uuid())
  agent_type      AgentType         @map("agent_type")
  action_type     String            @map("action_type")
  status          AgentActionStatus @default(PENDING) @map("status")
  contact_id      String?           @map("contact_id")
  user_id         String             @map("user_id")
  payload         Json               @map("payload")
  result          Json?              @map("result")
  compliance_result Json?            @map("compliance_result")
  created_at      DateTime          @default(now()) @map("created_at")
  completed_at    DateTime?         @map("completed_at")

  @@index([user_id, agent_type])
  @@index([user_id, status])
  @@index([created_at])
  @@map("agent_actions")
}

model AgentEventRecord {
  id                String    @id @default(uuid())
  agent_type        AgentType @map("agent_type")
  action_type       String    @map("action_type")
  user_id           String    @map("user_id")
  contact_id        String?   @map("contact_id")
  payload           Json      @map("payload")
  result            Json?     @map("result")
  compliance_passed  Boolean   @default(true) @map("compliance_passed")
  timestamp         DateTime  @default(now()) @map("timestamp")

  @@index([user_id, timestamp])
  @@index([agent_type, timestamp])
  @@map("agent_events")
}

model MissionControlState {
  id                          String   @id @default(uuid())
  user_id                     String   @unique @map("user_id")
  last_briefing_date          String?  @map("last_briefing_date")
  three_law_grow_score        Int      @default(0) @map("three_law_grow_score")
  three_law_engage_score      Int      @default(0) @map("three_law_engage_score")
  three_law_wealth_score      Int      @default(0) @map("three_law_wealth_score")
  inactivity_level            InactivityLevel @default(NONE) @map("inactivity_level")
  inactivity_days             Int      @default(0) @map("inactivity_days")
  weekly_ipa_count            Int      @default(0) @map("weekly_ipa_count")
  weekly_ipa_target           Int      @default(0) @map("weekly_ipa_target")
  momentum_score              Int      @default(0) @map("momentum_score")
  quota_weekly_target         Int      @default(0) @map("quota_weekly_target")
  quota_weekly_actual         Int      @default(0) @map("quota_weekly_actual")
  quota_monthly_target        Int      @default(0) @map("quota_monthly_target")
  quota_monthly_actual        Int      @default(0) @map("quota_monthly_actual")
  ipa_agent_ratio             Float    @default(0) @map("ipa_agent_ratio")
  ipa_field_trainer_ratio     Float    @default(0) @map("ipa_field_trainer_ratio")
  ipa_dollar_value            Int      @default(0) @map("ipa_dollar_value")
  updated_at                  DateTime @updatedAt @map("updated_at")

  @@map("mission_control_state")
}

model CorrectiveNudgeRecord {
  id                String    @id @default(uuid())
  user_id           String    @map("user_id")
  law               ThreeLaw  @map("law")
  severity          String    @map("severity")
  message           String    @map("message")
  suggested_action  String    @map("suggested_action")
  escalated_to_upline Boolean @default(false) @map("escalated_to_upline")
  dismissed_at      DateTime? @map("dismissed_at")
  created_at        DateTime  @default(now()) @map("created_at")

  @@index([user_id, law])
  @@index([created_at])
  @@map("corrective_nudges")
}