# Harvest App — Environment Variables Template
# Copy to .env.local for local development
# Add these to Vercel Dashboard > Settings > Environment Variables for production

# ─── Database ───
# PostgreSQL connection string (Supabase, Railway, Neon, or self-hosted)
DATABASE_URL="postgresql://user:password@host:5432/harvest?schema=public"

# ─── Authentication ───
# NextAuth session secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# JWT signing secret (generate fresh, do not reuse NEXTAUTH_SECRET)
JWT_SECRET="your-jwt-secret-here"

# ─── AI / LLM Providers ───
# OpenAI API key for AI agent layer (WP04)
OPENAI_API_KEY="sk-..."

# ─── Payment (Stripe) — WP10 ───
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ─── Messaging / Outreach — WP05 ───
# Convert & Flow (GoHighLevel) Private Integration Token
GHL_PIT="pit-..."

# Email delivery (SendGrid, Resend, or SES)
SMTP_HOST="smtp.sendgrid.net"
SMTP_API_KEY="SG."

# SMS delivery (Twilio)
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="..."
TWILIO_PHONE_NUMBER="+1..."

# ─── Compliance — WP11 ───
# Optional: external compliance audit webhook
COMPLIANCE_WEBHOOK_URL=""

# ─── App Config ───
# Node environment
NODE_ENV="development"
